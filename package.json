{
  "name": "tmt-library",
  "version": "1.0.4",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:python": "scripts\\build-python.bat",
    "build:python:mac": "bash scripts/build-python-mac.sh",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build:python && npm run build && electron-builder",
    "dist:win": "npm run dist -- --win",
    "dist:mac": "npm run build:python:mac && npm run build && electron-builder --mac",
    "release": "scripts\\release.bat",
    "make-ico": "node scripts/make-ico.js",
    "upload-release": "node scripts/upload-release.js"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "axios": "^1.13.6",
    "cropperjs": "^1.6.2",
    "echarts": "^5.6.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.9.7",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.0",
    "ali-oss": "^6.23.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "png-to-ico": "^2.1.8",
    "typescript": "^5.0.0",
    "vue": "^3.3.0"
  }
}
